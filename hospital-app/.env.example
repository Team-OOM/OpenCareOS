# OpenCareOS - Environment Variables Template
# Apache License 2.0
# Copy this file to .env and fill in your values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=OpenCareOS
APP_VERSION=0.1.0
APP_DESCRIPTION="The Open Source AI Operating Layer for Healthcare"
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# ===========================================
# SECURITY SETTINGS (CHANGE IN PRODUCTION!)
# ===========================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_SECRET=your-jwt-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080  # 7 days
JWT_REFRESH_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12

# ===========================================
# DATABASE SETTINGS
# ===========================================
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=secure-password-change-me
MONGO_DB_NAME=opencareos
MONGO_URI=mongodb://admin:secure-password-change-me@mongodb:27017
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=10

# ===========================================
# REDIS SETTINGS (for caching/sessions)
# ===========================================
REDIS_URL=redis://redis:6379/0

# ===========================================
# FILE UPLOAD SETTINGS
# ===========================================
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=52428800  # 50MB in bytes

# ===========================================
# EMAIL SETTINGS (for notifications)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=OpenCareOS <noreply@opencareos.org>

# ===========================================
# FRONTEND URL (for CORS)
# ===========================================
FRONTEND_URL=http://localhost:3000

# ===========================================
# AI SERVICE SETTINGS (for future integration)
# ===========================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
HERMES_API_URL=http://anurag-home-lab.local:5000

# ===========================================
# MONGO EXPRESS SETTINGS
# ===========================================
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=secure-password-change-me

# ===========================================
# LOGGING SETTINGS
# ===========================================
LOG_DIR=/app/logs
LOG_FORMAT=json